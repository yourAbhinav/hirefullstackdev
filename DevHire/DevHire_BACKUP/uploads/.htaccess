# Protect uploads directory
Options -Indexes

# Deny execution of scripts
<FilesMatch "\.(php|php5|phtml|pl|py|jsp|asp|aspx)$">
    <IfModule mod_authz_host.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_host.c>
        Deny from all
    </IfModule>
</FilesMatch>

# Serve only known safe file types
<IfModule mod_mime.c>
    RemoveHandler .php .phtml .php5
</IfModule>

# Prevent overriding by higher-level .htaccess
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
</IfModule>
